# ======================================================================
# Water Bill Extractor — Environment Variables
# ======================================================================

# Mistral Vision API
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=pixtral-12b-2409
MONGO_URI=mongodb+srv://your_mongo_user:your_mongo_password@cluster0.mongodb.net/

# Application
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50
HOST=0.0.0.0
PORT=8000

# OCR
OCR_CONFIDENCE_THRESHOLD=0.5

# PDF Conversion
PDF_DPI=300
